datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String     @unique
  email     String     @unique
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  teacherToken     TeacherToken?
  teacherProfile   TeacherProfile?
  sessionsTeaching Session[]         @relation("TeacherSessions")
  sessionsEnrolled SessionStudent[]
  availability     TeacherAvailability[]
  userSessions     UserSession[]
  bookings         Booking[]

  @@map("users")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

// Single-use 6-digit OTP codes. Raw code never stored — only bcrypt hash.
// failedAttempts: incremented on wrong guess; code invalidated after 5 failures.
model OtpCode {
  id             Int       @id @default(autoincrement())
  email          String
  codeHash       String
  expiresAt      DateTime
  usedAt         DateTime?
  failedAttempts Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([email, createdAt])
  @@map("otp_codes")
}

// Server-side sessions. Revocable by deleting the row.
model UserSession {
  id        Int      @id @default(autoincrement())
  sessionId String   @unique @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("user_sessions")
}

// ─── Teacher ──────────────────────────────────────────────────────────────────

// Token-gated read-only schedule URL. deletedAt set on removal → 404.
model TeacherToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique @default(cuid())
  teacherId Int       @unique
  teacher   User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("teacher_tokens")
}

// Bio + verification status for teacher-facing profile pages.
model TeacherProfile {
  id             Int                    @id @default(autoincrement())
  teacherId      Int                    @unique
  teacher        User                   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  bio            String?
  subjects       String[]               // e.g. ["JEE Physics", "JEE Chemistry"]
  verifyStatus   TeacherVerifyStatus    @default(PENDING)
  verifyNote     String?                // admin rejection reason
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@map("teacher_profiles")
}

enum TeacherVerifyStatus {
  PENDING
  APPROVED
  REJECTED
}

// Availability windows teachers propose; admin references when scheduling.
model TeacherAvailability {
  id        Int      @id @default(autoincrement())
  teacherId Int
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  note      String?
  createdAt DateTime @default(now())

  @@map("teacher_availability")
}

// ─── Courses ──────────────────────────────────────────────────────────────────

model GroupCourse {
  id          Int       @id @default(autoincrement())
  teacherId   Int
  title       String
  subject     String
  description String?
  maxStudents Int       @default(30)
  priceINR    Int       // paise (multiply by 100 for Razorpay)
  status      CourseStatus @default(DRAFT)
  createdAt   DateTime  @default(now())

  sessions Session[]
  bookings Booking[]

  @@map("group_courses")
}

enum CourseStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model OneOnOnePackage {
  id          Int      @id @default(autoincrement())
  teacherId   Int
  title       String
  subject     String
  sessions    Int      // total sessions in package
  durationMin Int      // minutes per session
  priceINR    Int      // paise
  status      CourseStatus @default(DRAFT)
  createdAt   DateTime @default(now())

  bookings     Booking[]
  slotProposals SlotProposal[]

  @@map("one_on_one_packages")
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id              Int           @id @default(autoincrement())
  teacherId       Int
  teacher         User          @relation("TeacherSessions", fields: [teacherId], references: [id])
  groupCourseId   Int?
  groupCourse     GroupCourse?  @relation(fields: [groupCourseId], references: [id])
  subject         String
  scheduledDate   DateTime
  durationMinutes Int
  meetLink        String?
  calendarEventId String?
  status          SessionStatus @default(SCHEDULED)
  cancelReason    String?
  emailSentAt     DateTime?
  emailError      String?
  reminderSentAt  DateTime?     // set by nightly cron after reminder email

  createdAt DateTime       @default(now())
  students  SessionStudent[]

  @@map("sessions")
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model SessionStudent {
  sessionId Int
  studentId Int
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User    @relation(fields: [studentId], references: [id])

  @@id([sessionId, studentId])
  @@map("session_students")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

// Polymorphic booking: exactly one of groupCourseId / oneOnOnePackageId is set.
model Booking {
  id                Int              @id @default(autoincrement())
  studentId         Int
  student           User             @relation(fields: [studentId], references: [id])
  groupCourseId     Int?
  groupCourse       GroupCourse?     @relation(fields: [groupCourseId], references: [id])
  oneOnOnePackageId Int?
  oneOnOnePackage   OneOnOnePackage? @relation(fields: [oneOnOnePackageId], references: [id])
  status            BookingStatus    @default(CONFIRMED)
  createdAt         DateTime         @default(now())

  @@map("bookings")
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

// ─── Slot Proposals (1-on-1 rolling schedule) ─────────────────────────────────

model SlotProposal {
  id                Int              @id @default(autoincrement())
  packageId         Int
  package           OneOnOnePackage  @relation(fields: [packageId], references: [id])
  proposedBy        ProposedBy
  startTime         DateTime
  endTime           DateTime
  status            SlotStatus       @default(PENDING)
  createdAt         DateTime         @default(now())

  @@map("slot_proposals")
}

enum ProposedBy {
  STUDENT
  TEACHER
}

enum SlotStatus {
  PENDING
  ACCEPTED
  REJECTED
}
