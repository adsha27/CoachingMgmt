generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                   @id @default(autoincrement())
  name                 String
  phone                String                @unique
  email                String                @unique
  password             String?
  loginAttempts        Int                   @default(0)
  lockedUntil          DateTime?
  targetExam           String?
  currentClass         String?
  role                 Role
  status               UserStatus            @default(ACTIVE)
  createdAt            DateTime              @default(now())
  bookings             Booking[]
  cancellationRequests CancellationRequest[] @relation("TeacherCancellations")
  groupCourses         GroupCourse[]
  inviteLinks          InviteLink[]
  oneOnOnePackages     OneOnOnePackage[]
  parentAccess         ParentAccess[]        @relation("StudentParents")
  feedbackGiven        SessionFeedback[]
  availability         TeacherAvailability[]
  teacherProfile       TeacherProfile?
  teacherToken         TeacherToken?
  topicRequests        TopicRequest[]
  parentSessions       UserSession[]         @relation("ParentStudentSessions")
  userSessions         UserSession[]         @relation("UserOwnSessions")
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  tokenHash String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model OtpCode {
  id             Int       @id @default(autoincrement())
  codeHash       String
  expiresAt      DateTime
  usedAt         DateTime?
  failedAttempts Int       @default(0)
  createdAt      DateTime  @default(now())
  phone          String

  @@index([phone, createdAt])
  @@map("otp_codes")
}

model UserSession {
  id              Int      @id @default(autoincrement())
  sessionId       String   @unique @default(cuid())
  userId          Int
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  parentStudentId Int?
  parentStudent   User?    @relation("ParentStudentSessions", fields: [parentStudentId], references: [id])
  user            User     @relation("UserOwnSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([parentStudentId])
  @@map("user_sessions")
}

model TeacherToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique @default(cuid())
  teacherId Int       @unique
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  teacher   User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_tokens")
}

model TeacherProfile {
  id                      Int                 @id @default(autoincrement())
  teacherId               Int                 @unique
  bio                     String?
  subjects                String[]
  verifyStatus            TeacherVerifyStatus @default(PENDING)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  demoVideoLink           String?
  profilePhotoUrl         String?
  qualifications          String?
  rating                  Float?
  rejectionReason         String?
  socialMediaLinks        Json?
  targetExams             String[]            @default([])
  expertiseTags           String[]            @default([])
  teachingExperienceYears Int?
  teacher                 User                @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_profiles")
}

model TeacherAvailability {
  id           Int                @id @default(autoincrement())
  teacherId    Int
  startTime    String
  endTime      String
  createdAt    DateTime           @default(now())
  dayOfWeek    DayOfWeek
  isRecurring  Boolean            @default(true)
  specificDate DateTime?          @db.Date
  status       AvailabilityStatus @default(AVAILABLE)
  teacher      User               @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_availability")
}

model GroupCourse {
  id                     Int                   @id @default(autoincrement())
  teacherId              Int
  title                  String
  subject                String
  description            String?
  maxStudents            Int                   @default(30)
  priceINR               Int
  originalPriceINR       Int?
  status                 CourseStatus          @default(DRAFT)
  createdAt              DateTime              @default(now())
  enrolledCount          Int                   @default(0)
  sessionDurationMinutes Int
  startDate              DateTime              @db.Date
  targetExam             String?
  totalSessions          Int
  bookings               Booking[]
  cancellationRequests   CancellationRequest[]
  teacher                User                  @relation(fields: [teacherId], references: [id])
  inviteLinks            InviteLink[]
  sessions               Session[]
  topicsFulfilled        TopicRequest[]        @relation("FulfilledByGroupCourse")

  @@map("group_courses")
}

model OneOnOnePackage {
  id                     Int                   @id @default(autoincrement())
  teacherId              Int
  title                  String
  subject                String
  priceINR               Int
  originalPriceINR       Int?
  status                 CourseStatus          @default(DRAFT)
  createdAt              DateTime              @default(now())
  description            String?
  sessionDurationMinutes Int
  targetExam             String?
  totalSessions          Int
  bookings               Booking[]
  cancellationRequests   CancellationRequest[]
  inviteLinks            InviteLink[]
  teacher                User                  @relation(fields: [teacherId], references: [id])
  topicsFulfilled        TopicRequest[]        @relation("FulfilledByPackage")

  @@map("one_on_one_packages")
}

model Session {
  id                   Int                   @id @default(autoincrement())
  groupCourseId        Int?
  durationMinutes      Int
  meetLink             String?
  calendarEventId      String?
  status               SessionStatus         @default(SCHEDULED)
  cancelReason         String?
  reminderSentAt       DateTime?
  createdAt            DateTime              @default(now())
  bookingId            Int?
  scheduledAt          DateTime
  sessionNumber        Int
  cancellationRequests CancellationRequest[]
  feedback             SessionFeedback[]
  booking              Booking?              @relation(fields: [bookingId], references: [id])
  groupCourse          GroupCourse?          @relation(fields: [groupCourseId], references: [id])

  @@map("sessions")
}

model Booking {
  id                Int              @id @default(autoincrement())
  studentId         Int
  groupCourseId     Int?
  oneOnOnePackageId Int?
  status            BookingStatus    @default(ACTIVE)
  bookedAt          DateTime         @default(now())
  courseType        CourseType
  sessionsCompleted Int              @default(0)
  sessionsRemaining Int
  sessionsScheduled Int              @default(0)
  totalSessions     Int
  groupCourse       GroupCourse?     @relation(fields: [groupCourseId], references: [id])
  oneOnOnePackage   OneOnOnePackage? @relation(fields: [oneOnOnePackageId], references: [id])
  student           User             @relation(fields: [studentId], references: [id])
  sessions          Session[]
  slotProposals     SlotProposal[]

  @@map("bookings")
}

model SlotProposal {
  id                Int        @id @default(autoincrement())
  status            SlotStatus @default(PENDING)
  createdAt         DateTime   @default(now())
  bookingId         Int
  proposedDate      DateTime   @db.Date
  proposedStartTime String
  teacherNote       String?
  booking           Booking    @relation(fields: [bookingId], references: [id])

  @@map("slot_proposals")
}

model SessionFeedback {
  id        Int      @id @default(autoincrement())
  sessionId Int
  studentId Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
  student   User     @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@map("session_feedback")
}

model TopicRequest {
  id                       Int                @id @default(autoincrement())
  studentId                Int
  subject                  String
  topicDescription         String
  status                   TopicRequestStatus @default(OPEN)
  fulfilledByGroupCourseId Int?
  fulfilledByPackageId     Int?
  createdAt                DateTime           @default(now())
  fulfilledByGroupCourse   GroupCourse?       @relation("FulfilledByGroupCourse", fields: [fulfilledByGroupCourseId], references: [id])
  fulfilledByPackage       OneOnOnePackage?   @relation("FulfilledByPackage", fields: [fulfilledByPackageId], references: [id])
  student                  User               @relation(fields: [studentId], references: [id])

  @@map("topic_requests")
}

model ParentAccess {
  id             Int       @id @default(autoincrement())
  studentId      Int
  parentName     String
  parentPhone    String
  parentEmail    String?
  verified       Boolean   @default(false)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())
  student        User      @relation("StudentParents", fields: [studentId], references: [id])

  @@unique([studentId, parentPhone])
  @@map("parent_access")
}

model InviteLink {
  id                Int              @id @default(autoincrement())
  teacherId         Int
  groupCourseId     Int?
  oneOnOnePackageId Int?
  code              String           @unique
  expiresAt         DateTime
  usesCount         Int              @default(0)
  createdAt         DateTime         @default(now())
  groupCourse       GroupCourse?     @relation(fields: [groupCourseId], references: [id])
  oneOnOnePackage   OneOnOnePackage? @relation(fields: [oneOnOnePackageId], references: [id])
  teacher           User             @relation(fields: [teacherId], references: [id])

  @@map("invite_links")
}

model CancellationRequest {
  id                Int                @id @default(autoincrement())
  teacherId         Int
  sessionId         Int?
  groupCourseId     Int?
  oneOnOnePackageId Int?
  reason            String
  status            CancellationStatus @default(PENDING)
  adminNote         String?
  createdAt         DateTime           @default(now())
  groupCourse       GroupCourse?       @relation(fields: [groupCourseId], references: [id])
  oneOnOnePackage   OneOnOnePackage?   @relation(fields: [oneOnOnePackageId], references: [id])
  session           Session?           @relation(fields: [sessionId], references: [id])
  teacher           User               @relation("TeacherCancellations", fields: [teacherId], references: [id])

  @@map("cancellation_requests")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TeacherVerifyStatus {
  PENDING
  VERIFIED
  REJECTED
  MORE_INFO_REQUESTED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum AvailabilityStatus {
  AVAILABLE
  BLOCKED
}

enum CourseStatus {
  DRAFT
  LISTED
  FULL
  CLOSED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CourseType {
  GROUP
  ONE_ON_ONE
}

enum BookingStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SlotStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum TopicRequestStatus {
  OPEN
  FULFILLED
}

enum CancellationStatus {
  PENDING
  APPROVED
  REJECTED
}
