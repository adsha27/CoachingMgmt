datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String     @unique
  email     String     @unique
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  teacherToken         TeacherToken?
  teacherProfile       TeacherProfile?
  availability         TeacherAvailability[]
  userSessions         UserSession[]         @relation("UserOwnSessions")
  parentSessions       UserSession[]         @relation("ParentStudentSessions")
  bookings             Booking[]
  topicRequests        TopicRequest[]
  parentAccess         ParentAccess[]        @relation("StudentParents")
  feedbackGiven        SessionFeedback[]
  groupCourses         GroupCourse[]
  oneOnOnePackages     OneOnOnePackage[]
  inviteLinks          InviteLink[]
  cancellationRequests CancellationRequest[] @relation("TeacherCancellations")

  @@map("users")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

// Single-use 6-digit OTP. phone is the identifier. bcrypt hash only — raw code never stored.
// failedAttempts: invalidated after 5 failures. Rate limit: 3 OTPs per phone per hour.
model OtpCode {
  id             Int       @id @default(autoincrement())
  phone          String
  codeHash       String
  expiresAt      DateTime
  usedAt         DateTime?
  failedAttempts Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([phone, createdAt])
  @@map("otp_codes")
}

// Server-side sessions. parentStudentId set for parent-scoped read-only sessions.
model UserSession {
  id              Int      @id @default(autoincrement())
  sessionId       String   @unique @default(cuid())
  userId          Int
  user            User     @relation("UserOwnSessions", fields: [userId], references: [id], onDelete: Cascade)
  parentStudentId Int?
  parentStudent   User?    @relation("ParentStudentSessions", fields: [parentStudentId], references: [id])
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([sessionId])
  @@index([parentStudentId])
  @@map("user_sessions")
}

// ─── Teacher ──────────────────────────────────────────────────────────────────

// Token-gated read-only schedule URL — kept for teachers who share the no-login URL.
model TeacherToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique @default(cuid())
  teacherId Int       @unique
  teacher   User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("teacher_tokens")
}

model TeacherProfile {
  id                      Int                 @id @default(autoincrement())
  teacherId               Int                 @unique
  teacher                 User                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  bio                     String?
  qualifications          String?
  subjects                String[]
  targetExams             String[]            @default([])
  profilePhotoUrl         String?
  teachingExperienceYears Int?
  demoVideoLink           String?
  socialMediaLinks        Json?
  verifyStatus            TeacherVerifyStatus @default(PENDING)
  rejectionReason         String?
  rating                  Float?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@map("teacher_profiles")
}

enum TeacherVerifyStatus {
  PENDING
  VERIFIED
  REJECTED
  MORE_INFO_REQUESTED
}

// Weekly availability grid. isRecurring=true → every week on dayOfWeek.
// specificDate + isRecurring=false → one-off slot or block.
// BLOCKED on specificDate overrides a recurring AVAILABLE for that date.
model TeacherAvailability {
  id           Int                @id @default(autoincrement())
  teacherId    Int
  teacher      User               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  dayOfWeek    DayOfWeek
  startTime    String             // "HH:MM" 24h
  endTime      String             // "HH:MM" 24h
  isRecurring  Boolean            @default(true)
  specificDate DateTime?          @db.Date
  status       AvailabilityStatus @default(AVAILABLE)
  createdAt    DateTime           @default(now())

  @@map("teacher_availability")
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum AvailabilityStatus {
  AVAILABLE
  BLOCKED
}

// ─── Courses ──────────────────────────────────────────────────────────────────

model GroupCourse {
  id                     Int          @id @default(autoincrement())
  teacherId              Int
  teacher                User         @relation(fields: [teacherId], references: [id])
  title                  String
  description            String?
  subject                String
  targetExam             String?
  totalSessions          Int
  sessionDurationMinutes Int
  priceINR               Int          // integer rupees (payments deferred — multiply by 100 for Razorpay when needed)
  maxStudents            Int          @default(30)
  enrolledCount          Int          @default(0)
  startDate              DateTime     @db.Date
  status                 CourseStatus @default(DRAFT)
  createdAt              DateTime     @default(now())

  sessions             Session[]
  bookings             Booking[]
  inviteLinks          InviteLink[]
  cancellationRequests CancellationRequest[]
  topicsFulfilled      TopicRequest[]        @relation("FulfilledByGroupCourse")

  @@map("group_courses")
}

model OneOnOnePackage {
  id                     Int          @id @default(autoincrement())
  teacherId              Int
  teacher                User         @relation(fields: [teacherId], references: [id])
  title                  String
  description            String?
  subject                String
  targetExam             String?
  totalSessions          Int
  sessionDurationMinutes Int
  priceINR               Int
  status                 CourseStatus @default(DRAFT)
  createdAt              DateTime     @default(now())

  bookings             Booking[]
  inviteLinks          InviteLink[]
  cancellationRequests CancellationRequest[]
  topicsFulfilled      TopicRequest[]        @relation("FulfilledByPackage")

  @@map("one_on_one_packages")
}

enum CourseStatus {
  DRAFT
  LISTED
  FULL
  CLOSED
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

// Unified session table.
// Group sessions: groupCourseId set, bookingId null (shared across all enrolled students).
// 1-on-1 sessions: bookingId set, groupCourseId null (per booking).
// Exactly one of the two FKs is non-null — enforced at application layer.
model Session {
  id              Int           @id @default(autoincrement())
  bookingId       Int?
  booking         Booking?      @relation(fields: [bookingId], references: [id])
  groupCourseId   Int?
  groupCourse     GroupCourse?  @relation(fields: [groupCourseId], references: [id])
  sessionNumber   Int
  scheduledAt     DateTime      // full date + time in UTC
  durationMinutes Int
  meetLink        String?
  calendarEventId String?
  status          SessionStatus @default(SCHEDULED)
  cancelReason    String?
  reminderSentAt  DateTime?
  createdAt       DateTime      @default(now())

  feedback             SessionFeedback[]
  cancellationRequests CancellationRequest[]

  @@map("sessions")
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

// Exactly one of groupCourseId / oneOnOnePackageId is non-null — enforced at application layer.
model Booking {
  id                Int              @id @default(autoincrement())
  studentId         Int
  student           User             @relation(fields: [studentId], references: [id])
  courseType        CourseType
  groupCourseId     Int?
  groupCourse       GroupCourse?     @relation(fields: [groupCourseId], references: [id])
  oneOnOnePackageId Int?
  oneOnOnePackage   OneOnOnePackage? @relation(fields: [oneOnOnePackageId], references: [id])
  totalSessions     Int
  sessionsCompleted Int              @default(0)
  sessionsScheduled Int              @default(0)
  sessionsRemaining Int
  bookedAt          DateTime         @default(now())
  status            BookingStatus    @default(ACTIVE)

  sessions      Session[]
  slotProposals SlotProposal[]

  @@map("bookings")
}

enum CourseType {
  GROUP
  ONE_ON_ONE
}

enum BookingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Slot Proposals (1-on-1 rolling schedule) ─────────────────────────────────

model SlotProposal {
  id                Int        @id @default(autoincrement())
  bookingId         Int
  booking           Booking    @relation(fields: [bookingId], references: [id])
  proposedDate      DateTime   @db.Date
  proposedStartTime String     // "HH:MM" 24h
  status            SlotStatus @default(PENDING)
  teacherNote       String?
  createdAt         DateTime   @default(now())

  @@map("slot_proposals")
}

enum SlotStatus {
  PENDING
  CONFIRMED
  REJECTED
}

// ─── Session Feedback ─────────────────────────────────────────────────────────

model SessionFeedback {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
  studentId Int
  student   User     @relation(fields: [studentId], references: [id])
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  @@unique([sessionId, studentId])
  @@map("session_feedback")
}

// ─── Topic Requests ───────────────────────────────────────────────────────────

model TopicRequest {
  id                       Int                @id @default(autoincrement())
  studentId                Int
  student                  User               @relation(fields: [studentId], references: [id])
  subject                  String
  topicDescription         String
  status                   TopicRequestStatus @default(OPEN)
  fulfilledByGroupCourseId Int?
  fulfilledByGroupCourse   GroupCourse?       @relation("FulfilledByGroupCourse", fields: [fulfilledByGroupCourseId], references: [id])
  fulfilledByPackageId     Int?
  fulfilledByPackage       OneOnOnePackage?   @relation("FulfilledByPackage", fields: [fulfilledByPackageId], references: [id])
  createdAt                DateTime           @default(now())

  @@map("topic_requests")
}

enum TopicRequestStatus {
  OPEN
  FULFILLED
}

// ─── Parent Access ────────────────────────────────────────────────────────────

model ParentAccess {
  id             Int       @id @default(autoincrement())
  studentId      Int
  student        User      @relation("StudentParents", fields: [studentId], references: [id])
  parentName     String
  parentPhone    String
  parentEmail    String?
  verified       Boolean   @default(false)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())

  @@unique([studentId, parentPhone])
  @@map("parent_access")
}

// ─── Invite Links ─────────────────────────────────────────────────────────────

// Exactly one of groupCourseId / oneOnOnePackageId is non-null — enforced at application layer.
model InviteLink {
  id                Int              @id @default(autoincrement())
  teacherId         Int
  teacher           User             @relation(fields: [teacherId], references: [id])
  groupCourseId     Int?
  groupCourse       GroupCourse?     @relation(fields: [groupCourseId], references: [id])
  oneOnOnePackageId Int?
  oneOnOnePackage   OneOnOnePackage? @relation(fields: [oneOnOnePackageId], references: [id])
  code              String           @unique
  expiresAt         DateTime
  usesCount         Int              @default(0)
  createdAt         DateTime         @default(now())

  @@map("invite_links")
}

// ─── Cancellation Requests ────────────────────────────────────────────────────

// Teacher requests cancellation of a specific session OR an entire group course OR a 1-on-1 package.
// Exactly one of sessionId / groupCourseId / oneOnOnePackageId is non-null.
model CancellationRequest {
  id                Int                @id @default(autoincrement())
  teacherId         Int
  teacher           User               @relation("TeacherCancellations", fields: [teacherId], references: [id])
  sessionId         Int?
  session           Session?           @relation(fields: [sessionId], references: [id])
  groupCourseId     Int?
  groupCourse       GroupCourse?       @relation(fields: [groupCourseId], references: [id])
  oneOnOnePackageId Int?
  oneOnOnePackage   OneOnOnePackage?   @relation(fields: [oneOnOnePackageId], references: [id])
  reason            String
  status            CancellationStatus @default(PENDING)
  adminNote         String?
  createdAt         DateTime           @default(now())

  @@map("cancellation_requests")
}

enum CancellationStatus {
  PENDING
  APPROVED
  REJECTED
}
