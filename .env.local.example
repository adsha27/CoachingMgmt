# Copy to .env.local and fill in values. Never commit .env.local.

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/coaching_mgmt"

# Google Calendar service account
# Encode the JSON key file: base64 -i path/to/key.json | pbcopy
GOOGLE_SERVICE_ACCOUNT_KEY="<base64-encoded service account JSON>"
# The Google Workspace email that owns the calendar (impersonated by service account)
GOOGLE_CALENDAR_OWNER_EMAIL="calendar@yourworkspacedomain.com"

# Resend email delivery (used for all transactional email + OTP when AUTH_MODE=email)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourverifieddomain.com"

# MSG91 SMS OTP — required when AUTH_MODE=phone
# API key: https://msg91.com → API → Auth Key
MSG91_API_KEY="your-msg91-api-key"
# DLT-registered template ID (must be approved before going live)
MSG91_TEMPLATE_ID="your-dlt-template-id"

# Auth mode: "phone" (MSG91 SMS OTP) or "email" (Resend email OTP — use during MSG91 DLT approval)
AUTH_MODE="phone"

# Base URL for links in emails and invite codes
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Secret for the nightly reminder cron endpoint
# Generate: openssl rand -hex 32
CRON_SECRET="replace-with-random-secret"

# Local dev: fixed OTP for a test phone number (non-production only)
DEV_FIXED_OTP_PHONE="9999999999"
DEV_FIXED_OTP_CODE="123456"
DEV_AUTH_BYPASS="true"
