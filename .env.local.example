# Copy to .env.local and fill in values. Never commit .env.local.

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/coaching_mgmt"

# Google Calendar service account
# Encode the JSON key file: base64 -i path/to/key.json | pbcopy
GOOGLE_SERVICE_ACCOUNT_KEY="<base64-encoded service account JSON>"
# The Google Workspace email that owns the calendar (impersonated by service account)
GOOGLE_CALENDAR_OWNER_EMAIL="calendar@yourworkspacedomain.com"

# Resend email delivery
RESEND_API_KEY="re_..."
# The verified sender address in your Resend account
EMAIL_FROM="noreply@yourverifieddomain.com"

# Base URL for generating teacher schedule links
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Secret for the nightly reminder cron endpoint
# Generate: openssl rand -hex 32
CRON_SECRET="replace-with-random-secret"

# Local-only OTP shortcut for seeded admin testing
DEV_FIXED_OTP_EMAIL="admin@example.test"
DEV_FIXED_OTP_CODE="123456"
DEV_AUTH_BYPASS="true"
