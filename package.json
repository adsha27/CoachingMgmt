{
  "name": "coaching-mgmt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "if [ \"$VERCEL_ENV\" = production ]; then prisma migrate deploy; fi && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:e2e": "playwright test",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "email:dev": "email dev --dir lib/emails --port 3001",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --run",
    "test:db": "node scripts/test-db.mjs unit",
    "test:e2e:db": "node scripts/test-db.mjs e2e",
    "ci": "npm run typecheck && npx prisma validate && npm run test:db && npm run test:e2e:db && npm run build",
    "db:migrate": "node --env-file=.env.local node_modules/prisma/build/index.js migrate deploy",
    "db:seed-marketplace": "node scripts/seed-marketplace-demo.mjs",
    "db:seed": "node scripts/seed-admin.mjs",
    "db:demo": "node scripts/seed-admin.mjs && node scripts/seed-demo.mjs",
    "seed": "tsx --env-file=.env.local prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@react-email/components": "^1.0.12",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "googleapis": "^144.0.0",
    "next": "^16.2.6",
    "nodemailer": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^6.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/forms": "^0.5.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
